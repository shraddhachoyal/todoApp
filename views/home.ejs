<!doctype html>
<html lang="en">

    <head>
        <title>Todos</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    </head>
    <body>
        <style type="text/css" media="screen">
            body {
                background-color: #87ceeb57;
                text-decoration-color: white;
                /* font-size: 7em; */
            }
            table{
                width: 60%;
                margin: 20px auto;
                border-collapse: collapse;
            }

            th,td{
                border:1px solid #ccc;
                padding:10px;
            }

            th{
                background: #121111d9;
                color: white;
                font-size: 18px;

            }
            /* toggle button */
            .toggle_true{
                color: #0a0a0a;
                background-color: #1ba919b3;
                border-color: #127a11b3;
                border-radius: 6px;
                padding: 5px;
            }
            .toggle_false{
                color: #0a0a0a;
                background-color: #e9b112;
                border-color: #b38503;
                border-radius: 6px;
                padding: 5px;
            }
            /* Heading */
            h1{
                text-align: center;
                text-shadow: 1px 1px black;
            }
            button{
                border-radius: 6px;
                padding: 5px;
            }
            /* search & sort form */
            .filter-form{
                /* width:60%;
                margin:20px auto; */
                display:flex;
                gap:10px;
                justify-content:center;
            }

            .filter-form input,
            .filter-form select{
                padding:8px;
                font-size:11px;
            }

            .filter-form button{
                padding:8px 15px;
                cursor:pointer;
            }
            .addBtn{
                background: #007bff;
                color: white;
                border-color: #007bff;
            }
            /* pagination */
            .pagination{
                margin-top:20px;
                text-align:center;
            }

            .pagination a{
                text-decoration:none;
                padding:4px 8px;
                margin:0 4px;
                border:1px solid #ccc;
                border-radius:5px;
                color:black;
            }

            .pagination a.active{
                background:#007bff;
                color:white;
                border-color:#007bff;
            }

            .pagination a:hover{
                background:#0056b3;
                color:white;
            }
            .danger{
                color: #0a0a0a;
                background-color: #b90909;
                border-color: #890606;
            }
            
            .warning{
                color: #0a0a0a;
                background-color: #b97b09;
                border-color: #8d5f0c;
            }
        </style>
        <h1>Todo List</h1>
        <!-- Search and Sort form-->
        <form action="/todos" method="GET" class="filter-form">        
            <input type="text" name="search" placeholder="Search title..." value="<%= search || '' %>">
        
            <select name="sort">
                <option value="">Sort</option>        
                <option value="asc" <%= sort === 'asc' ? 'selected' : '' %>>Oldest First</option>        
                <option value="desc" <%= sort === 'desc' ? 'selected' : '' %>> Newest First </option>
            </select>
            <button type="submit">Search</button>
            <button class="addBtn" type="button" data-bs-toggle="modal" data-bs-target="#addTodoModal">Add New</button>
        </form>
        <!-- end -->
        
        <!-- Start list -->
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                
                <% todos.forEach(todo => { %>
                <tr>
                    <td><%= todo.title %></td>
                    <td><%= todo.description %></td>
                    <td>
                        <button type="button" class="toggle_<%= todo.isCompleted %>" onClick="toggleTodo('<%= todo._id %>', this)"><%= todo.isCompleted ? "Completed" : "Pending" %></button> 
                    </td>
                    <td>
                        <button type="button" class="warning" onclick="openEditModal('<%= todo._id %>','<%= todo.title %>','<%= todo.description %>')">Edit</button>
                        <button type="button" class="danger" onClick="deleteTodo('<%= todo._id %>', this)">Delete</button>
                    </td>
                </tr>
                <% }) %>
                
            </tbody>
        </table>
        <!-- end -->
        <div class="pagination">
        
            <% if(page > 1){ %>
            <a href="/todos?page=<%= page-1 %>&limit=<%= limit %>&search=<%= search || '' %>&sort=<%= sort || '' %>">Previous</a>
            <% } %>
        
            <% for(let i = 1; i <= totalPages; i++){ %>        
                <a href="/todos?page=<%= i %>&limit=<%= limit %>&search=<%= search || '' %>&sort=<%= sort || '' %>" class="<%= page === i ? 'active' : '' %>">
                    <%= i %>
                </a>
            <% } %>
        
            <% if(page < totalPages){ %>
            <a href="/todos?page=<%= page+1 %>&limit=<%= limit %>&search=<%= search || '' %>&sort=<%= sort || '' %>">Next</a>
            <% } %>
        
        </div>
        
        <!-- Add todo modal start -->
        <div class="modal fade" id="addTodoModal">        
            <div class="modal-dialog">        
                <div class="modal-content">        
                    <div class="modal-header">
                        <h5>Add Todo</h5>        
                        <button class="btn-close" data-bs-dismiss="modal">  </button>
                    </div>
        
                    <div class="modal-body">        
                        <form id="todoForm">        
                            <input type="text" id="title" class="form-control mb-2" placeholder="Title">        
                            <textarea id="description" class="form-control" name="description" value="" placeholder="Description"></textarea>
                        </form>        
                    </div>        
                    <div class="modal-footer">        
                        <button class="btn btn-secondary" data-bs-dismiss="modal"> Close </button>        
                        <button class="btn btn-success" onclick="saveTodo()"> Save</button>
                    </div>        
                </div>        
            </div>        
        </div>
        <!-- end add modal -->

        <!-- editModal start -->
        <div class="modal fade" id="editTodoModal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Edit Todo</h5>
                        <button class="btn-close" data-bs-dismiss="modal"> </button>
                    </div>
        
                    <div class="modal-body">
                        <form id="todoForm">
                            <input type="hidden" id="todoId" name="title" value="" class="form-control mb-2" placeholder="Title">
                            <input type="text" id="editTitle" name="description" value="" class="form-control mb-2" placeholder="Title">
                            <textarea id="editDescription" class="form-control" name="description" value=""
                                placeholder="Description"></textarea>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal"> Close </button>
                        <button class="btn btn-success" onclick="updateTodo()"> Save</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- end of editModal -->
        <script>
            async function updateTodo(){
                try{
                    const id = document.getElementById("todoId").value;
                    const title = document.getElementById("editTitle").value;
                    const description = document.getElementById("editDescription").value;
                    
                    const response = await fetch("/todos/" + id, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            title,
                            description
                        })
                    })

                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    console.log(error);
                    alert("Something went wrong.");
                }
            }
            
            async function openEditModal(id,title,description){
                
                document.getElementById("todoId").value = id;
                document.getElementById("editTitle").value = title;
                document.getElementById("editDescription").value = description;

                const modal = new bootstrap.Modal(
                    document.getElementById("editTodoModal")
                );

                modal.show();
            }

            async function saveTodo(){
                try{
                    const title = document.getElementById("title").value;
                    const description = document.getElementById("description").value;

                    const response = await fetch("/todos/add", { 
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            title,
                            description
                        })
                    });
                    const result = await response.json();
                    if (result.success) {
                        location.reload();
                    }else{
                        alert(result.message);
                    }
                } catch(error){
                    console.log(error);
                    alert("Something went wrong.");
                }
            }
            async function toggleTodo(id, button) {
                try {
                    const response = await fetch(`/todos/${id}`, {method: "PATCH"});
                    const result = await response.json();

                    if (result.success) {
                        //If isCompleted = true
                        if (result.data.isCompleted) {                            
                            button.innerText = "Completed";
                            button.classList.remove("toggle_false");
                            button.classList.add("toggle_true");
                        } else {                            
                            // If isCompleted = false
                            button.innerText = "Pending";
                            button.classList.remove("toggle_true");
                            button.classList.add("toggle_false");
                        }
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    console.log(error);
                    alert("Something went wrong.");
                }
            }

            async function deleteTodo(id, button) {
                const confirmDelete = confirm("Are you sure you want to delete this todo?");

                if (!confirmDelete) return;
                
                try {
                    const response = await fetch(`/todos/${id}`, { method: "DELETE" });
                    // console.log(response);
                    
                    const result = await response.json();

                    if (result.success) {
                        alert('Todo Successfully deleted');
                        location.reload();
                    } else {
                        alert(result.message);
                    }

                } catch (error) {
                    console.log(error);
                    alert("Something went wrong.");
                }
            }

        </script>
    </body>
</html>